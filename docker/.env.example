# ================================================================
# AIMScribe AI Backend - Environment Configuration
# ================================================================
# Copy this file to .env and fill in your values

# ================================================================
# Azure OpenAI - Transcription
# ================================================================
AZURE_TRANSCRIBE_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_TRANSCRIBE_API_KEY=your_transcription_api_key
AZURE_TRANSCRIBE_DEPLOYMENT=gpt-4o-transcribe

# ================================================================
# Azure OpenAI - NER & Agents
# ================================================================
AZURE_NER_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_NER_API_KEY=your_ner_api_key
AZURE_NER_DEPLOYMENT=gpt-4
AZURE_API_VERSION=2024-02-15-preview

# ================================================================
# PostgreSQL Database
# ================================================================
POSTGRES_USER=aimscribe_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=aimscribe_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_EXTERNAL_PORT=5432

# ================================================================
# MinIO Object Storage
# ================================================================
MINIO_ACCESS_KEY=aimscribe
MINIO_SECRET_KEY=aimscribe123
MINIO_BUCKET=aimscribe-audio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ================================================================
# Redis Message Queue
# ================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_EXTERNAL_PORT=6379

# ================================================================
# Server Configuration
# ================================================================
SERVER_PORT=6000
LOG_LEVEL=INFO

# ================================================================
# Processing Configuration
# ================================================================
NER_TRIGGER_CLIPS=2
WORKER_CONCURRENCY=1
